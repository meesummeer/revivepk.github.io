# Copy to .env in this folder. Used when running the API (npm run dev or npm start).

# Get your key at https://resend.com
RESEND_API_KEY=re_xxxxx

# Where to send form submissions (default: meesumdameer@gmail.com)
TO_EMAIL=meesumdameer@gmail.com

# Sender address (trial: use onboarding@resend.dev; production: use a verified domain)
FROM_EMAIL=Revive Website <onboarding@resend.dev>
